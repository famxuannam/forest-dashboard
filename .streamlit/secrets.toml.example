# Sao chép file này thành .streamlit/secrets.toml rồi điền giá trị thật (KHÔNG commit file
# đã điền, secrets.toml đã có trong .gitignore).
#
# Lấy từ Supabase: mở project -> Settings -> API.
#   SUPABASE_URL = mục "Project URL"
#   SUPABASE_KEY = mục "Project API keys" -> "anon" "public"
#
# App bắt buộc phải có 2 giá trị này mới chạy được (không còn chế độ CSV cục bộ) -- thiếu file
# này hoặc thiếu 1 trong 2 giá trị, app sẽ báo lỗi cấu hình ngay khi mở.

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Tuỳ chọn -- chỉ cần nếu dùng tính năng "Đồng bộ lịch Work" (mục 5, tab Chuẩn bị dữ liệu).
# ICLOUD_APP_PASSWORD tạo tại appleid.apple.com -> Sign-In and Security -> App-Specific
# Passwords (KHÔNG phải mật khẩu Apple ID thật). ICLOUD_WORK_CALENDAR là tên lịch cần đồng bộ
# trong Apple Calendar, đổi nếu bạn đặt tên khác "Work". Thiếu 3 giá trị này thì mục "Đồng bộ
# lịch Work" sẽ báo lỗi cấu hình khi bấm nút, các phần còn lại của app vẫn chạy bình thường.
ICLOUD_USERNAME = "your_apple_id@example.com"
ICLOUD_APP_PASSWORD = "xxxx-xxxx-xxxx-xxxx"
ICLOUD_WORK_CALENDAR = "Work"

# Tuỳ chọn -- bật cổng đăng nhập bằng Google (chỉ 1 tài khoản được vào app). Xem hướng dẫn tạo
# OAuth Client ID + điền các giá trị bên dưới trong mục "Đăng nhập Google (tuỳ chọn)" của README.
# Thiếu mục [auth] này thì app chạy KHÔNG có cổng đăng nhập (giữ hành vi cũ). Đã có [auth] thì
# BẮT BUỘC phải có ALLOWED_EMAIL, thiếu sẽ báo lỗi cấu hình ngay khi mở app (an toàn mặc định).
ALLOWED_EMAIL = "ban@gmail.com"

[auth]
redirect_uri = "https://ten-app-cua-ban.streamlit.app/oauth2callback"
cookie_secret = "mot-chuoi-ngau-nhien-tu-nghi-ra-du-dai"
client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
